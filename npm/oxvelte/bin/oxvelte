#!/usr/bin/env node

const { execFileSync } = require("child_process");
const path = require("path");

const PLATFORMS = {
  "darwin-arm64": "@oxvelte/cli-darwin-arm64",
  "darwin-x64": "@oxvelte/cli-darwin-x64",
  "linux-x64": "@oxvelte/cli-linux-x64-gnu",
  "linux-arm64": "@oxvelte/cli-linux-arm64-gnu",
  "win32-x64": "@oxvelte/cli-win32-x64-msvc",
};

function getBinaryPath() {
  const platformKey = `${process.platform}-${process.arch}`;
  const pkg = PLATFORMS[platformKey];

  if (!pkg) {
    console.error(
      `oxvelte: unsupported platform ${process.platform}-${process.arch}\n` +
        `Supported: ${Object.keys(PLATFORMS).join(", ")}`
    );
    process.exit(1);
  }

  try {
    const pkgPath = require.resolve(`${pkg}/package.json`);
    const binName = process.platform === "win32" ? "oxvelte.exe" : "oxvelte";
    return path.join(path.dirname(pkgPath), binName);
  } catch {
    console.error(
      `oxvelte: could not find the binary package "${pkg}".\n` +
        `This usually means the optional dependency was not installed.\n` +
        `Try: npm install oxvelte --force`
    );
    process.exit(1);
  }
}

const bin = getBinaryPath();

try {
  execFileSync(bin, process.argv.slice(2), { stdio: "inherit" });
} catch (e) {
  if (e.status !== undefined) {
    process.exit(e.status);
  }
  throw e;
}
